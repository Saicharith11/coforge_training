<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans
         http://www.springframework.org/schema/beans/spring-beans.xsd">

    
    <bean id="customer1" class="com.coforge.model.Customer">
        <property name="customerId" value="101"/>
        <property name="customerName" value="charith"/>
        
        
        <property name="emails">
            <list>
                <value>Charith@gmail.com</value>
                <value>Cherry@outlook.com</value>
            </list>
        </property>

        
        <property name="deliveryAddress">
            <list>
                <ref bean="deliveryAddress1"/>
                <ref bean="deliveryAddress2"/>
            </list>
        </property>
    </bean>

  
    <bean id="deliveryAddress1" class="com.coforge.model.DeliveryAddress">
        <property name="city" value="City-1"/>
        <property name="state" value="State-1"/>
    </bean>

    <bean id="deliveryAddress2" class="com.coforge.model.DeliveryAddress">
        <property name="city" value="City-2"/>
        <property name="state" value="State-2"/>
    </bean>

</beans>